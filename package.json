{
  "name": "aiguard",
  "displayName": "AiGuard",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onCommand:aiguard.showMenu",
    "onCommand:aiguard.startGuard",
    "onCommand:aiguard.pauseGuard",
    "onCommand:aiguard.scanFile",
    "onCommand:aiguard.openSettings",
    "onCommand:aiguard.viewReport"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiguard.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "aiguard.showMenu",
        "title": "AI Guard: Show Menu"
      },
      {
        "command": "aiguard.startGuard",
        "title": "AI Guard: Start Guard"
      },
      {
        "command": "aiguard.pauseGuard",
        "title": "AI Guard: Pause Guard"
      },
      {
        "command": "aiguard.scanFile",
        "title": "AI Guard: Scan Current File"
      },
      {
        "command": "aiguard.openSettings",
        "title": "AI Guard: Open Settings"
      },
      {
        "command": "aiguard.viewReport",
        "title": "AI Guard: View Report"
      }
    ],
    "configuration": {
      "title": "AI Code Guard",
      "properties": {
        "aiCodeGuard.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for AI Guard service"
        },
        "aiCodeGuard.apiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "AI API endpoint URL"
        },
        "aiCodeGuard.aiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "AI model used for code analysis"
        },
        "aiCodeGuard.apiTimeoutMs": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Timeout for AI API requests in milliseconds"
        },
        "aiCodeGuard.maxAnalyzedChars": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Maximum number of code characters sent to AI API"
        },
        "aiCodeGuard.localRules.consoleStatements": {
          "type": "boolean",
          "default": false,
          "description": "Enable local rule that flags console.log/warn/error statements"
        },
        "aiCodeGuard.scanMode": {
          "type": "string",
          "enum": [
            "realtime",
            "onDemand",
            "preCommit"
          ],
          "default": "realtime",
          "description": "Code scanning mode"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
